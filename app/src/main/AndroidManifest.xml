<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet permissions for WebView -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Foreground Service permissions -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <!-- Microphone permissions -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Notification permissions (API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Wake lock for keeping audio alive -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Boot completed (optional, for auto-restart) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Vibration -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".AdoetzGPTApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AdoetzGPT"
        android:usesCleartextTraffic="true"
        tools:targetApi="35">

        <!-- Main Activity - WebView Container -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|navigation|uiMode"
            android:launchMode="singleTask"
            android:alwaysRetainTaskState="true"
            android:documentLaunchMode="never"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.AdoetzGPT">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Backend Configuration Activity -->
        <activity
            android:name=".ui.BackendConfigActivity"
            android:exported="false"
            android:label="@string/backend_settings"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.AdoetzGPT" />

        <!-- Voice Session Foreground Service -->
        <service
            android:name=".service.VoiceSessionService"
            android:exported="false"
            android:foregroundServiceType="microphone"
            android:stopWithTask="false" />

        <!-- Notification Channel for Voice Session -->
        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>

        <!-- Provider for DataStore -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:replace="android:authorities">

            <!-- Initialize DataStore -->
            <meta-data
                android:name="androidx.datastore.DataStoreInitializer"
                android:value="androidx.startup" />
        </provider>

    </application>

    <!-- Microphone intent filter for Android 14+ -->
    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

</manifest>
